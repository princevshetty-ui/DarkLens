# DarkLens Environment Configuration
# Copy this to .env and fill in your values

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Backend Configuration
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Frontend Configuration
# Leave empty to use same-origin /api paths.
# Set in production when frontend and backend are on different domains.
VITE_API_BASE_URL=

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:5173,http://127.0.0.1:8000

# Database
DATABASE_URL=sqlite:///data/cache.sqlite

# Uvicorn
UVICORN_TIMEOUT_KEEP_ALIVE=5
